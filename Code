<script>
// ── NAVIGATION
const pages=['home','about','work','services','booking','portal'];
const navIds=['home','about','work','services','booking'];
function go(name){
  pages.forEach(p=>document.getElementById('page-'+p).classList.remove('on'));
  navIds.forEach(n=>{const el=document.getElementById('nl-'+n);if(el)el.classList.remove('on');});
  document.getElementById('page-'+name).classList.add('on');
  const nl=document.getElementById('nl-'+name);if(nl)nl.classList.add('on');
  window.scrollTo(0,0);
  document.getElementById('navLinks').classList.remove('open');
  document.getElementById('siteFooter').style.display=name==='portal'?'none':'block';
  setTimeout(initSR,80);
}

// ── SCROLL REVEAL
const observer=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');observer.unobserve(e.target);}});
},{threshold:0.05,rootMargin:'0px 0px -16px 0px'});
function initSR(){
  document.querySelectorAll('.sr,.sr-left,.sr-right,.sr-scale').forEach(el=>{
    el.classList.remove('visible');
    observer.observe(el);
  });
}
setTimeout(initSR,120);

// ── BOOKING
let selectedPlan='Starter';
function selectPlan(el,plan){
  document.querySelectorAll('.booking-card').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected');selectedPlan=plan;
}
function submitBooking(){
  const first=document.getElementById('bFirst').value.trim();
  const email=document.getElementById('bEmail').value.trim();
  if(!first||!email){document.getElementById('bOk').textContent='Please fill in your name and email.';return;}
  document.getElementById('bOk').textContent='Request received! We\'ll be in touch within 24 hours.';
  ['bFirst','bLast','bEmail','bPhone','bBiz','bMsg'].forEach(id=>document.getElementById(id).value='');
}

// ── PORTAL
// ════════════════════════════════════════════════
// ADD YOUR CLIENTS HERE — format: 'CODE':'Client Name'
const CLIENTS={
  // Add client codes below this line:

};
// ════════════════════════════════════════════════
let pFiles=[];
function pLogin(){
  const code=document.getElementById('pCodeInput').value.toUpperCase().trim();
  if(CLIENTS[code]){
    document.getElementById('pLogin').style.display='none';
    document.getElementById('pDash').style.display='block';
    document.getElementById('pClientName').textContent=CLIENTS[code];
    document.getElementById('pErrMsg').textContent='';
  }else{document.getElementById('pErrMsg').textContent='Invalid code. Please check with Bryski Studios.';}
}
function pLogout(){
  document.getElementById('pLogin').style.display='flex';
  document.getElementById('pDash').style.display='none';
  document.getElementById('pCodeInput').value='';
  document.getElementById('pFileList').innerHTML='';
  document.getElementById('pSendBtn').classList.add('hidden');
  document.getElementById('pOkMsg').textContent='';
  pFiles=[];
}
document.getElementById('pCodeInput').addEventListener('keydown',e=>{if(e.key==='Enter')pLogin();});
function pTab(name,btn){
  document.querySelectorAll('.ptab-body').forEach(t=>t.classList.remove('on'));
  document.querySelectorAll('.ptab').forEach(b=>b.classList.remove('on'));
  document.getElementById('ptab-'+name).classList.add('on');btn.classList.add('on');
  if(name==='messages'){const n=document.getElementById('pNotifBadge');if(n)n.style.display='none';}
}
function pHandleFiles(e){
  pFiles=Array.from(e.target.files);
  document.getElementById('pOkMsg').textContent='';
  document.getElementById('pFileList').innerHTML=pFiles.map(f=>`
    <div class="f-row"><div class="f-dot fp"></div><div class="f-name">${f.name}</div><div class="f-size">${(f.size/1024/1024).toFixed(1)} MB</div></div>`).join('');
  document.getElementById('pSendBtn').classList.remove('hidden');
}
function pSendFiles(){
  const btn=document.getElementById('pSendBtn');
  btn.textContent='Sending...';btn.disabled=true;
  setTimeout(()=>{
    document.getElementById('pFileList').innerHTML=pFiles.map(f=>`
      <div class="f-row"><div class="f-dot fs"></div><div class="f-name">${f.name}</div><div class="f-size" style="color:#0D0D0D;font-weight:800;">Sent ✓</div></div>`).join('');
    btn.classList.add('hidden');btn.disabled=false;btn.textContent='Send To Bryski Studios';
    document.getElementById('pOkMsg').textContent='Received — Bryski Studios will be in touch shortly.';
    pFiles=[];
  },1500);
}
function pSendMsg(){
  const f=document.getElementById('pMsgInput');
  const t=f.value.trim();if(!t)return;
  const th=document.getElementById('pMsgThread');
  const time=new Date().toLocaleTimeString([],{hour:'numeric',minute:'2-digit'});
  th.innerHTML+=`<div class="mb me"><div class="mb-text">${t}</div><div class="mb-time">Now ${time}</div></div>`;
  f.value='';th.scrollTop=th.scrollHeight;
  setTimeout(()=>{
    th.innerHTML+=`<div class="mb them"><div class="mb-sender">Bryski Studios</div><div class="mb-text">Got it — we'll follow up shortly.</div><div class="mb-time">Just Now</div></div>`;
    th.scrollTop=th.scrollHeight;
  },1200);
}

// ── CHATBOT
const chatResponses={
  'services':'We offer done-for-you monthly content systems including video production, social media management, reels & short-form content, ad creative, and content strategy. All planned, filmed, edited, and scheduled for you.',
  'cost':'Pricing is custom based on your scope and goals. Book a free call and we\'ll put together a package that works for your business.',
  'started':'Easy! Just click "Book A Free Call" and fill out the form. We\'ll reach out within 24 hours to schedule your strategy call.',
  'located':'We\'re based in Arizona.',
  'long':'We film your entire month of content in a single shoot day, then deliver edited videos within 5–7 business days.',
  'contracts':'We work on monthly agreements with no long-term lock-in. We earn your business every single month.',
  'businesses':'We work with restaurants, gyms, barbershops, real estate agents, retail brands, and any service business that wants to grow on social media.',
};
function toggleChat(){document.getElementById('chatPanel').classList.toggle('open');}
function chatQ(q){addChatMsg(q,'user');setTimeout(()=>handleChatReply(q),700);}
function sendChat(){
  const inp=document.getElementById('chatInput');
  const msg=inp.value.trim();if(!msg)return;
  addChatMsg(msg,'user');inp.value='';
  setTimeout(()=>handleChatReply(msg),800);
}
function addChatMsg(text,role){
  const thread=document.getElementById('chatMessages');
  const time=new Date().toLocaleTimeString([],{hour:'numeric',minute:'2-digit'});
  thread.innerHTML+=`<div class="chat-bubble ${role}"><div class="chat-btext">${text}</div><div class="chat-btime">${time}</div></div>`;
  thread.scrollTop=thread.scrollHeight;
}
function handleChatReply(msg){
  const lower=msg.toLowerCase();
  let reply='Great question! Book a free call and we\'ll give you all the details. Click "Book A Free Call" in the nav above.';
  for(const key in chatResponses){if(lower.includes(key)){reply=chatResponses[key];break;}}
  addChatMsg(reply,'bot');
}


// ── FAQ
function toggleFaq(el){
  const item=el.parentElement;
  const isOpen=item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));
  if(!isOpen)item.classList.add('open');
}

go('home');
</script>
