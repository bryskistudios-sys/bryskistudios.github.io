<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Bryski Studios — Social Media & Video Marketing</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{--black:#0D0D0D;--white:#fff;--gray:#F5F5F5;--gray2:#EFEFEF;--border:#E8E8E8;--muted:#999;}
html{scroll-behavior:smooth;}
body{font-family:'Montserrat',sans-serif;background:#fff;color:#0D0D0D;overflow-x:hidden;text-transform:uppercase;}

/* ── SCROLL REVEAL ─────────────────── */
.sr{opacity:0;transform:translateY(20px);transition:opacity 1s ease,transform 1s ease;will-change:opacity,transform;}
.sr.d1{transition-delay:.12s;}.sr.d2{transition-delay:.22s;}.sr.d3{transition-delay:.32s;}.sr.d4{transition-delay:.42s;}.sr.d5{transition-delay:.52s;}
.sr.visible{opacity:1;transform:none;}
.sr-left{opacity:0;transform:translateX(-20px);transition:opacity 1s ease,transform 1s ease;will-change:opacity,transform;}
.sr-left.visible{opacity:1;transform:none;}
.sr-right{opacity:0;transform:translateX(20px);transition:opacity 1s ease,transform 1s ease;will-change:opacity,transform;}
.sr-right.visible{opacity:1;transform:none;}
.sr-scale{opacity:0;transform:scale(0.97);transition:opacity .9s ease,transform .9s ease;will-change:opacity,transform;}
.sr-scale.visible{opacity:1;transform:none;}

/* ── NAV ─────────────────────────────── */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:0 48px;height:62px;background:#fff;border-bottom:1px solid var(--border);}
.nav-logo{font-size:13px;font-weight:900;letter-spacing:3px;color:var(--black);cursor:pointer;}
.nav-links{display:flex;align-items:center;gap:32px;}
.nav-links a{font-size:8px;font-weight:800;letter-spacing:2.5px;color:var(--muted);cursor:pointer;transition:color .2s;text-decoration:none;position:relative;}
.nav-links a::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:1px;background:var(--black);transition:width .3s cubic-bezier(.16,1,.3,1);}
.nav-links a:hover::after,.nav-links a.on::after{width:100%;}
.nav-links a:hover,.nav-links a.on{color:var(--black);}
.nav-portal{font-size:8px;font-weight:900;letter-spacing:2px;color:#fff;background:var(--black);border:none;padding:10px 22px;cursor:pointer;font-family:'Montserrat',sans-serif;text-transform:uppercase;transition:opacity .2s;}
.nav-portal:hover{opacity:.8;}
.burger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;}
.burger span{display:block;width:22px;height:2px;background:var(--black);}
@media(max-width:768px){
  nav{padding:0 20px;}
  .nav-links{display:none;position:fixed;top:62px;left:0;right:0;background:#fff;flex-direction:column;align-items:flex-start;padding:24px 20px;border-bottom:1px solid var(--border);gap:20px;}
  .nav-links.open{display:flex;}
  .burger{display:flex;}
}

/* ── PAGE SYSTEM ─────────────────────── */
.page{display:none;padding-top:62px;}
.page.on{display:block;animation:pageIn .4s ease both;}
@keyframes pageIn{from{opacity:0;}to{opacity:1;}}

/* ── BUTTONS ─────────────────────────── */
.btn-blk{display:inline-block;padding:15px 36px;background:var(--black);color:#fff;border:none;font-family:'Montserrat',sans-serif;font-size:9px;font-weight:900;letter-spacing:3px;text-transform:uppercase;cursor:pointer;transition:opacity .25s;text-decoration:none;}
.btn-blk:hover{opacity:.75;}
.btn-wht{display:inline-block;padding:15px 36px;background:#fff;color:var(--black);border:2px solid var(--black);font-family:'Montserrat',sans-serif;font-size:9px;font-weight:900;letter-spacing:3px;text-transform:uppercase;cursor:pointer;transition:all .2s;text-decoration:none;}
.btn-wht:hover{background:var(--black);color:#fff;}

/* ── HOME ────────────────────────────── */
.hero{
  min-height:calc(100vh - 62px);
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  text-align:center;padding:80px 48px 120px;
  position:relative;overflow:hidden;
  border-bottom:1px solid var(--border);
}
.hero-tag{
  font-size:8px;letter-spacing:5px;color:var(--muted);font-weight:800;margin-bottom:28px;
  animation:heroUp 1s .1s ease both;
}
.hero-h1{
  font-size:clamp(52px,9vw,128px);font-weight:900;letter-spacing:-1px;
  line-height:.95;color:var(--black);margin-bottom:24px;white-space:nowrap;
  animation:heroUp 1.1s .2s ease both;
}
.hero-h2{
  font-size:clamp(12px,1.6vw,18px);font-weight:800;letter-spacing:2px;
  color:var(--black);margin-bottom:16px;
  animation:heroUp 1.1s .35s ease both;
}
.hero-p{
  font-size:9px;letter-spacing:2px;color:var(--muted);max-width:440px;
  line-height:2.2;font-weight:600;margin-bottom:44px;
  animation:heroUp 1.1s .48s ease both;
}
.hero-btns{
  display:flex;gap:14px;justify-content:center;flex-wrap:wrap;
  animation:heroUp 1.1s .6s ease both;
}
.hero-scroll{
  position:absolute;bottom:32px;left:50%;transform:translateX(-50%);
  font-size:7px;letter-spacing:3px;color:var(--muted);font-weight:700;
  display:flex;flex-direction:column;align-items:center;gap:8px;
  animation:heroUp 1s .8s ease both;
}
.scroll-line{
  width:1px;height:40px;background:var(--border);
  animation:scrollPulse 2s ease-in-out infinite;
  transform-origin:top;
}
@keyframes heroUp{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:none;}}
@keyframes scrollPulse{0%,100%{opacity:.6;}50%{opacity:.15;}}
@media(max-width:768px){
  .hero{padding:60px 24px 100px;}
  .hero-h1{white-space:normal;font-size:clamp(40px,14vw,80px);}
}

/* MARQUEE */
.marquee-bar{border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:18px 0;overflow:hidden;white-space:nowrap;background:#fff;}
.marquee-inner{display:inline-block;animation:marquee 20s linear infinite;}
.marquee-bar:hover .marquee-inner{animation-play-state:paused;}
.mi{display:inline-block;font-size:9px;font-weight:800;letter-spacing:4px;color:var(--muted);margin:0 36px;}
.md{display:inline-block;width:4px;height:4px;background:var(--black);border-radius:50%;vertical-align:middle;margin:0 16px;}
@keyframes marquee{from{transform:translateX(0);}to{transform:translateX(-50%);}}

/* DONE FOR YOU */
.dfy{display:grid;grid-template-columns:1fr 1fr;min-height:500px;}
.dfy-left{background:var(--black);padding:80px 56px;display:flex;flex-direction:column;justify-content:center;}
.dfy-right{background:var(--gray);padding:80px 56px;display:flex;flex-direction:column;justify-content:center;}
.dfy-tag{font-size:8px;letter-spacing:4px;color:rgba(255,255,255,.4);margin-bottom:16px;font-weight:700;}
.dfy-h{font-size:clamp(24px,3.5vw,40px);font-weight:900;letter-spacing:1px;line-height:1.1;color:#fff;margin-bottom:20px;}
.dfy-p{font-size:9px;letter-spacing:1.5px;line-height:2.4;color:rgba(255,255,255,.6);font-weight:600;margin-bottom:36px;}
.dfy-steps{display:flex;flex-direction:column;gap:16px;}
.dfy-step{display:flex;align-items:flex-start;gap:16px;transition:transform .3s cubic-bezier(.16,1,.3,1);}
.dfy-step:hover{transform:translateX(8px);}
.dfy-step-num{font-size:9px;font-weight:900;letter-spacing:2px;color:rgba(255,255,255,.3);min-width:28px;padding-top:1px;}
.dfy-step-text{font-size:9px;letter-spacing:1.5px;line-height:2;color:rgba(255,255,255,.75);font-weight:700;}
.dfy-r-tag{font-size:8px;letter-spacing:4px;color:var(--muted);margin-bottom:16px;font-weight:700;}
.dfy-r-h{font-size:clamp(24px,3.5vw,40px);font-weight:900;letter-spacing:1px;line-height:1.1;color:var(--black);margin-bottom:20px;}
.dfy-r-p{font-size:9px;letter-spacing:1.5px;line-height:2.4;color:var(--muted);font-weight:600;margin-bottom:36px;}
.dfy-stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:8px;}
.dfy-stat{border:1px solid var(--border);padding:20px;transition:border-color .2s,transform .3s cubic-bezier(.16,1,.3,1);}
.dfy-stat:hover{border-color:var(--black);transform:translateY(-3px);}
.dfy-stat-n{font-size:28px;font-weight:900;letter-spacing:1px;color:var(--black);}
.dfy-stat-l{font-size:8px;letter-spacing:2px;color:var(--muted);margin-top:4px;font-weight:700;}
@media(max-width:768px){.dfy{grid-template-columns:1fr;}.dfy-left,.dfy-right{padding:56px 28px;}}

/* CTA STRIP */
.cta-strip{background:var(--black);padding:80px 48px;display:flex;align-items:center;justify-content:space-between;gap:40px;flex-wrap:wrap;}
.cta-strip-h{font-size:clamp(24px,4vw,48px);font-weight:900;letter-spacing:1px;line-height:1;color:#fff;}
.cta-strip-sub{font-size:9px;letter-spacing:2px;color:rgba(255,255,255,.5);margin-top:10px;font-weight:600;}

/* ── ABOUT ───────────────────────────── */
.about-hero{padding:100px 48px 72px;border-bottom:1px solid var(--border);}
.about-hero-inner{max-width:860px;}
.about-eyebrow{font-size:8px;letter-spacing:5px;color:var(--muted);font-weight:800;margin-bottom:16px;}
.about-h{font-size:clamp(40px,8vw,86px);font-weight:900;letter-spacing:2px;line-height:.95;margin-bottom:36px;}
.about-lead{font-size:11px;letter-spacing:1.5px;line-height:2.4;color:var(--muted);font-weight:600;max-width:640px;}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:0;}
.about-l{padding:72px 48px;border-right:1px solid var(--border);}
.about-r{padding:72px 48px;}
.about-body{font-size:9px;letter-spacing:1.5px;line-height:2.6;color:var(--muted);font-weight:600;margin-bottom:32px;}
.about-vals{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);}
.about-val{background:#fff;padding:28px;font-size:9px;transition:background .2s,transform .3s cubic-bezier(.16,1,.3,1);}
.about-val:hover{background:var(--gray);transform:translateY(-2px);}
.about-val-t{font-weight:900;letter-spacing:2px;margin-bottom:8px;color:var(--black);}
.about-val-p{color:var(--muted);line-height:2;letter-spacing:1px;font-weight:600;}
@media(max-width:768px){.about-grid{grid-template-columns:1fr;}.about-l{border-right:none;border-bottom:1px solid var(--border);padding:48px 24px;}.about-r{padding:48px 24px;}.about-hero{padding:60px 24px 48px;}}

/* ── OUR WORK ──────────────────────── */
.section{padding:88px 48px;}
.sec-tag{font-size:8px;letter-spacing:4px;color:var(--muted);font-weight:800;margin-bottom:10px;}
.sec-h{font-size:clamp(32px,5.5vw,60px);font-weight:900;letter-spacing:1px;line-height:1;margin-bottom:52px;}
.work-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;}
.work-item{position:relative;overflow:hidden;aspect-ratio:4/5;background:var(--gray);cursor:pointer;}
.work-item.wide{grid-column:span 2;aspect-ratio:auto;min-height:380px;}
.work-bg{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:52px;transition:transform .5s cubic-bezier(.16,1,.3,1);}
.work-item:hover .work-bg{transform:scale(1.06);}
.work-overlay{position:absolute;inset:0;background:rgba(13,13,13,0);display:flex;flex-direction:column;justify-content:flex-end;padding:28px;transition:background .3s;}
.work-item:hover .work-overlay{background:rgba(13,13,13,.78);}
.work-info{opacity:0;transform:translateY(10px);transition:all .35s cubic-bezier(.16,1,.3,1);}
.work-item:hover .work-info{opacity:1;transform:translateY(0);}
.work-cat{font-size:7px;letter-spacing:3px;color:rgba(255,255,255,.6);font-weight:800;margin-bottom:6px;}
.work-title{font-size:14px;font-weight:900;letter-spacing:1px;color:#fff;}
@media(max-width:768px){.work-grid{grid-template-columns:1fr;}.work-item.wide{grid-column:span 1;min-height:280px;}}

/* ── BOOKING ─────────────────────────── */
.booking-hero{padding:80px 48px 0;text-align:center;}
.booking-h{font-size:clamp(36px,7vw,72px);font-weight:900;letter-spacing:2px;line-height:1;margin-bottom:16px;}
.booking-sub{font-size:9px;letter-spacing:2px;color:var(--muted);font-weight:600;max-width:400px;margin:0 auto 56px;line-height:2;}
.booking-options{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;margin-bottom:3px;}
.booking-card{background:var(--gray);padding:40px 32px;cursor:pointer;transition:background .2s,transform .3s cubic-bezier(.16,1,.3,1);border:2px solid transparent;}
.booking-card:hover{background:var(--gray2);transform:translateY(-4px);}
.booking-card.selected{background:#fff;border-color:var(--black);}
.booking-plan{font-size:8px;letter-spacing:3px;color:var(--muted);font-weight:800;margin-bottom:12px;}
.booking-name{font-size:18px;font-weight:900;letter-spacing:1px;margin-bottom:8px;}
.booking-price{font-size:28px;font-weight:900;color:var(--black);margin-bottom:4px;}
.booking-price-sub{font-size:8px;letter-spacing:1.5px;color:var(--muted);font-weight:700;margin-bottom:20px;}
.booking-features{list-style:none;display:flex;flex-direction:column;gap:10px;}
.booking-features li{font-size:8px;letter-spacing:1.5px;color:var(--muted);font-weight:700;display:flex;align-items:center;gap:10px;}
.booking-features li::before{content:'';width:5px;height:5px;background:var(--black);border-radius:50%;flex-shrink:0;}
.booking-form-wrap{padding:56px 48px;}
.booking-form-h{font-size:20px;font-weight:900;letter-spacing:2px;margin-bottom:32px;}
.bform{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.bform-full{grid-column:span 2;}
.field-label{font-size:8px;letter-spacing:3px;color:var(--muted);font-weight:700;margin-bottom:8px;display:block;}
.field-input{width:100%;padding:14px 16px;background:var(--gray);border:1px solid var(--border);font-family:'Montserrat',sans-serif;font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--black);outline:none;transition:border .2s,box-shadow .2s;}
.field-input:focus{border-color:var(--black);box-shadow:0 0 0 3px rgba(13,13,13,.06);}
.field-input::placeholder{color:#ccc;}
textarea.field-input{resize:vertical;min-height:100px;}
.bform-submit{width:100%;padding:16px;background:var(--black);color:#fff;border:none;font-family:'Montserrat',sans-serif;font-size:10px;font-weight:900;letter-spacing:4px;text-transform:uppercase;cursor:pointer;transition:opacity .2s,transform .15s;margin-top:8px;}
.bform-submit:hover{opacity:.75;}
.bform-ok{font-size:9px;letter-spacing:2px;color:var(--black);margin-top:12px;min-height:14px;font-weight:700;}
@media(max-width:768px){.booking-options{grid-template-columns:1fr;}.bform{grid-template-columns:1fr;}.bform-full{grid-column:span 1;}.booking-form-wrap{padding:40px 24px;}.booking-hero{padding:60px 24px 0;}}

/* ── PORTAL ──────────────────────────── */
.portal-login{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:calc(100vh - 62px);padding:60px 20px;background:#fff;}
.p-brand{font-size:clamp(36px,8vw,68px);font-weight:900;letter-spacing:3px;text-align:center;line-height:1;}
.p-sub{font-size:9px;letter-spacing:5px;color:var(--muted);margin-top:10px;text-align:center;font-weight:700;}
.p-rule{width:48px;height:3px;background:var(--black);margin:32px auto;}
.p-box{width:100%;max-width:400px;padding:40px;border:1px solid var(--border);}
.p-label{font-size:8px;letter-spacing:3px;color:var(--muted);font-weight:700;margin-bottom:10px;display:block;}
.p-code{width:100%;padding:18px;background:var(--gray);border:1px solid var(--border);font-size:24px;letter-spacing:10px;text-align:center;font-family:'Montserrat',sans-serif;font-weight:900;text-transform:uppercase;color:var(--black);outline:none;transition:border .2s;}
.p-code:focus{border-color:var(--black);}
.p-code::placeholder{color:#D8D8D8;font-size:16px;letter-spacing:5px;}
.p-go{display:block;width:100%;margin-top:14px;padding:17px;background:var(--black);color:#fff;border:none;font-family:'Montserrat',sans-serif;font-size:10px;font-weight:900;letter-spacing:4px;text-transform:uppercase;cursor:pointer;transition:opacity .2s;}
.p-go:hover{opacity:.8;}
.p-err{font-size:9px;letter-spacing:1px;color:#bbb;margin-top:10px;text-align:center;min-height:14px;font-weight:700;}
.p-dash{display:none;}
.p-topbar{display:flex;align-items:center;justify-content:space-between;padding:18px 48px;border-bottom:2px solid var(--black);}
.p-topbar-logo{font-size:13px;font-weight:900;letter-spacing:3px;}
.p-topbar-r{display:flex;align-items:center;gap:16px;}
.p-client{font-size:9px;letter-spacing:2px;color:var(--muted);font-weight:700;}
.p-out{font-size:9px;letter-spacing:2px;color:var(--black);background:#fff;border:1.5px solid var(--black);padding:10px 22px;cursor:pointer;font-family:'Montserrat',sans-serif;font-weight:800;text-transform:uppercase;transition:all .2s;}
.p-out:hover{background:var(--black);color:#fff;}
.p-tabs{display:flex;border-bottom:1px solid var(--border);padding:0 48px;gap:4px;}
.ptab{padding:18px 30px;font-size:10px;letter-spacing:3px;font-weight:800;font-family:'Montserrat',sans-serif;text-transform:uppercase;border:none;background:none;cursor:pointer;color:#bbb;border-bottom:3px solid transparent;margin-bottom:-1px;transition:all .2s;white-space:nowrap;}
.ptab:hover{color:var(--black);}
.ptab.on{color:var(--black);border-bottom-color:var(--black);}
.ptab-badge{display:inline-block;background:var(--black);color:#fff;font-size:8px;padding:2px 7px;margin-left:8px;font-weight:900;}
.ptab-body{display:none;padding:48px;}
.ptab-body.on{display:block;}
.ptab-eyebrow{font-size:8px;letter-spacing:4px;color:var(--muted);font-weight:700;margin-bottom:8px;}
.ptab-title{font-size:26px;font-weight:900;letter-spacing:1px;margin-bottom:36px;line-height:1;}
.drop-zone{border:2px dashed #D8D8D8;padding:52px 24px;text-align:center;cursor:pointer;position:relative;background:var(--gray);transition:all .2s;}
.drop-zone:hover{border-color:var(--black);background:var(--gray2);}
.drop-zone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.dz-icon{font-size:28px;opacity:.4;display:block;margin-bottom:12px;}
.dz-main{font-size:10px;letter-spacing:2px;font-weight:800;}
.dz-sub{font-size:8px;letter-spacing:1.5px;color:var(--muted);margin-top:6px;font-weight:700;}
.f-list{margin-top:16px;display:flex;flex-direction:column;gap:6px;}
.f-row{display:flex;align-items:center;gap:12px;background:var(--gray);border:1px solid var(--border);padding:12px 16px;}
.f-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.fp{background:#ccc;}.fs{background:var(--black);}
.f-name{flex:1;font-size:9px;letter-spacing:1px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:700;}
.f-size{font-size:9px;color:var(--muted);flex-shrink:0;font-weight:700;}
.p-btn{display:block;width:100%;margin-top:20px;padding:16px;background:var(--black);color:#fff;border:none;font-family:'Montserrat',sans-serif;font-size:10px;font-weight:900;letter-spacing:4px;text-transform:uppercase;cursor:pointer;transition:opacity .2s;}
.p-btn:hover{opacity:.8;}
.p-btn:disabled{opacity:.35;}
.p-ok{font-size:9px;letter-spacing:2px;text-align:center;margin-top:12px;min-height:14px;font-weight:700;}
.d-list{display:flex;flex-direction:column;}
.d-row{display:flex;align-items:center;gap:20px;padding:20px 0;border-bottom:1px solid var(--border);}
.d-row:last-child{border-bottom:none;}
.d-thumb{width:58px;height:42px;background:var(--gray);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.d-info{flex:1;}
.d-name{font-size:11px;font-weight:800;letter-spacing:2px;}
.d-meta{font-size:8px;letter-spacing:1px;color:var(--muted);margin-top:4px;font-weight:600;}
.d-btn{font-size:9px;font-weight:900;letter-spacing:2px;color:var(--black);background:#fff;border:1.5px solid var(--black);padding:11px 22px;cursor:pointer;font-family:'Montserrat',sans-serif;text-transform:uppercase;white-space:nowrap;transition:all .2s;}
.d-btn:hover{background:var(--black);color:#fff;}
.msg-wrap{border:1px solid var(--border);overflow:hidden;}
.msg-thread{display:flex;flex-direction:column;gap:16px;padding:24px;max-height:320px;overflow-y:auto;background:var(--gray);}
.mb{display:flex;flex-direction:column;max-width:75%;}
.mb.me{align-self:flex-end;align-items:flex-end;}
.mb.them{align-self:flex-start;align-items:flex-start;}
.mb-sender{font-size:7px;letter-spacing:2px;color:var(--muted);margin-bottom:4px;font-weight:700;}
.mb-text{padding:13px 18px;font-size:9px;letter-spacing:.8px;line-height:1.8;font-weight:600;}
.me .mb-text{background:var(--black);color:#fff;}
.them .mb-text{background:#fff;border:1px solid var(--border);color:var(--black);}
